# 桥监听
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=3847

# 安全（可选；OpenClaw 请求需带 Authorization: Bearer <value>）
BRIDGE_API_KEY=any-token-you-want

# cursor-agent
CURSOR_AGENT_BIN=cursor-agent
CURSOR_WORKSPACE="/Users/xuyehua/Library/Mobile Documents/iCloud~md~obsidian/Documents/yehua的笔记"
CURSOR_AGENT_TIMEOUT_MS=180000
CURSOR_AGENT_MODEL=
CURSOR_AGENT_EXTRA_ARGS=--trust
# 仅使用最近 N 条消息拼 prompt，避免第二句起 prompt 过大导致超时/无回复。0=不限制
CURSOR_MAX_MESSAGES=20
# 单轮模式：只取 1 条 system + 1 条当前 user，不带历史。设成 1/true 开启；无多轮记忆
# CURSOR_SINGLE_TURN=0
# 调试：把每次发给 cursor-agent 的完整 prompt 写入 .cursor-bridge-last-prompt.txt，并在终端打印长度与头尾。设成 1 开启
# CURSOR_DEBUG_PROMPT=0
# 强制非流式：客户端请求 stream: true 时也走非流式，便于排查「200 但无回复」并生成 .cursor-bridge-last-stdout.txt。设成 1 开启
# CURSOR_FORCE_NON_STREAM=1

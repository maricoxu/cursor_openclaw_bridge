# 桥监听
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=3847

# 安全（可选；OpenClaw 请求需带 Authorization: Bearer <value>）
BRIDGE_API_KEY=any-token-you-want

# cursor-agent（可执行文件名或绝对路径）
# 填 cursor-agent 时，桥会从 PATH 及常见目录（~/.local/bin、/usr/local/bin、/opt/homebrew/bin）自动查找，pm2 下也无需手写绝对路径；若仍找不到可改为绝对路径如 /Users/你/.local/bin/cursor-agent
CURSOR_AGENT_BIN=cursor-agent
CURSOR_WORKSPACE="/path/to/your/workspace"
CURSOR_AGENT_TIMEOUT_MS=180000
# 模型：填 auto 让 Cursor 自动选（省用量、避免 slow pool 503）；留空则用 Cursor 当前默认（可能是贵模型）
CURSOR_AGENT_MODEL=auto
CURSOR_AGENT_EXTRA_ARGS=--trust
# 仅使用最近 N 条消息拼 prompt，避免第二句起 prompt 过大导致超时/无回复。0=不限制
CURSOR_MAX_MESSAGES=20
# 单轮模式：只取 1 条 system + 1 条当前 user，不带历史。设成 1/true 开启；无多轮记忆
# CURSOR_SINGLE_TURN=0
# 调试：把每次发给 cursor-agent 的完整 prompt 写入 .cursor-bridge-last-prompt.txt，并在终端打印长度与头尾。设成 1 开启
# CURSOR_DEBUG_PROMPT=0
# 强制非流式：客户端请求 stream: true 时也走非流式；便于排查「无回复」「第二句转圈/循环」并生成 .cursor-bridge-last-stdout.txt。设成 1 开启
# CURSOR_FORCE_NON_STREAM=1
# 流式时是否展示 thinking/reasoning：设成 1 或 true 时，思考内容作为「前期输出」先推，result 再作为最终输出，体感更连贯；默认不展示
# CURSOR_STREAM_SHOW_THINKING=0
# thinking 块前缀，默认「思考：」；设为空字符串则不加前缀
# CURSOR_STREAM_THINKING_PREFIX=思考：
# 流式超时提示：超过 N 毫秒仍未收到 result/thinking 时，先推一条提示（避免长时间空白）；0 或未设则关闭。常用 10000～20000
# CURSOR_STREAM_WAITING_MSG_AFTER_MS=0
# 超时提示文案，默认「处理时间较长，请稍候。」
# CURSOR_STREAM_WAITING_MSG_TEXT=处理时间较长，请稍候。

# ---------- Phase 3 Memory（可选） ----------
# 总开关：设为 1/true 开启 Memory 注入、按 agent 分发 workspace、请求结束写回 daily。关闭后行为与未实现 Phase 3 一致
# CURSOR_BRIDGE_MEMORY_ENABLED=0
# 注入 memory 时是否强制单轮（1 system + 1 user）
# CURSOR_BRIDGE_MEMORY_SINGLE_TURN=0
# 请求结束后是否写回 memory/YYYY-MM-DD.md
# CURSOR_BRIDGE_UPDATE_DAILY=0
# agent_id 映射：Header X-Agent-Id 或 body.agent_id → 子路径，格式 id1:path1,id2:path2
# CURSOR_BRIDGE_AGENT_WORKSPACES=00_小哩中枢:7-Agents/00_小哩中枢
# 近/远/他 Agent 字符限额：默认不设（0=不限额）。需要控 token 或做数据分析时可设为正数
# CURSOR_BRIDGE_MEMORY_NEAR_MAX_ROOT=0
# CURSOR_BRIDGE_MEMORY_NEAR_MAX_DAILY_TODAY=0
# CURSOR_BRIDGE_MEMORY_NEAR_MAX_DAILY_YESTERDAY=0
# CURSOR_BRIDGE_MEMORY_NEAR_MAX_AGENT=0
# 远层：更早 N 天的 daily（0=不读远层）；每文件限额 0=不限额
# CURSOR_BRIDGE_MEMORY_FAR_DAYS=0
# CURSOR_BRIDGE_MEMORY_FAR_MAX_PER_DAY=0
# 是否注入其他 Agent 的 MEMORY；每 Agent 限额 0=不限额
# CURSOR_BRIDGE_MEMORY_OTHER_AGENTS=0
# CURSOR_BRIDGE_MEMORY_OTHER_MAX_PER_AGENT=0
# 写回 daily 限频（分钟）
# CURSOR_BRIDGE_DAILY_WRITE_THROTTLE_MIN=5
